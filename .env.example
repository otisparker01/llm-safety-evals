# Copy to .env and fill in the key for whichever provider you evaluate.
# Inspect reads these automatically. See https://inspect.aisi.org.uk/providers.html
#
# The default model is local Ollama (ollama/qwen3:8b) and needs NO API key — just
# Ollama running on your machine. Keys below are only for hosted models.

# Ollama (default; e.g. --model ollama/qwen3:8b). No key required.
# Only set this if Ollama runs somewhere other than the default localhost:11434.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic (e.g. --model anthropic/claude-sonnet-4-6)
# ANTHROPIC_API_KEY=

# OpenAI (e.g. --model openai/gpt-4o)
# OPENAI_API_KEY=

# Google (e.g. --model google/gemini-2.5-pro)
# GOOGLE_API_KEY=

# Optional: default model so you can omit --model
# INSPECT_EVAL_MODEL=anthropic/claude-sonnet-4-6
